# ── Required ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxx
CHARTLI_PIN=changeme123
DATABASE_URL=sqlite:///./chartli.db

# ── LLM ────────────────────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ── Whisper ────────────────────────────────────────────────────────────────────
WHISPER_MODEL=whisper-large-v3-turbo
WHISPER_LANGUAGE=en
WHISPER_TIMEOUT_SECONDS=30
WHISPER_MAX_AUDIO_MB=25
WHISPER_MAX_AUDIO_SECONDS=600

# ── Context injection ──────────────────────────────────────────────────────────
HISTORY_VISITS_TO_INJECT=3
HISTORY_MAX_TOKENS=6000

# ── Misc ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
CLINIC_TIMEZONE=Asia/Karachi

# ── Postgres (prod) ────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/chartli
